{
  "name": "sasagram",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "deps:check": "depcruise --config .dependency-cruiser.cjs src",
    "deps:graph": "node scripts/generate-dependency-graph.mjs",
    "db:setup": "node --env-file=.env.local scripts/setup-db.mjs",
    "db:dedupe-streams": "node --env-file=.env.local scripts/dedupe-streams.mjs",
    "db:import-2026": "node --env-file=.env.local scripts/import-streams-2026.mjs",
    "db:import-vods-2026": "node --env-file=.env.local scripts/import-twitch-vods-2026.mjs",
    "db:migrate-to-supabase": "node --env-file=.env.local scripts/migrate-to-supabase.mjs"
  },
  "dependencies": {
    "@dotlottie/player-component": "^2.7.12",
    "@neondatabase/serverless": "^1.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.18",
    "next": "^16.1.3",
    "pg": "^8.19.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-slot-counter": "^3.3.2",
    "swiper": "^12.1.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
